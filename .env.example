# Copy to `.env` for local dev. Tests load `.env.test` (also gitignored)
# and should point DATABASE_URL at a separate database, e.g. crop_planner_test.

# Server
PORT=3000

# Required for Auth (Slice 3+)
DATABASE_URL=postgresql://localhost:5432/crop_planner_dev
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=

# RevenueCat Webhook (Slice 5+)
REVENUECAT_WEBHOOK_AUTH_HEADER=

# Stripe (Slice 6+)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
ENABLE_STRIPE_EXTERNAL_LINK=true

# Next.js Website (Slice 12+)
NEXT_PUBLIC_API_URL=
