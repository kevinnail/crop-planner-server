{
  "name": "crop-planner-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:apply-schema": "tsx src/db/apply-schema.ts",
    "db:apply-schema:test": "tsx --env-file=.env.test src/db/apply-schema.ts",
    "db:studio": "drizzle-kit studio",
    "manual:password-reset": "tsx scripts/manual-password-reset.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1071.0",
    "@aws-sdk/s3-request-presigner": "3.1071.0",
    "@better-auth/expo": "1.6.14",
    "better-auth": "1.6.14",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.0",
    "postgres": "^3.4.0",
    "resend": "^6.12.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^3.2.4",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "supertest": "^7.1.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "@better-auth/core": "1.6.14"
  }
}
